{
  "name": "robomed-backend",
  "version": "1.0.0",
  "description": "RoboMed AI Healthcare Platform — Node.js/Express Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --runInBand --detectOpenHandles --forceExit",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.12.1",
    "socket.io": "^4.7.5",
    "streamifier": "^0.1.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/setup/globalSetup.js",
    "globalTeardown": "./tests/setup/globalTeardown.js",
    "setupFilesAfterEnv": [],
    "testTimeout": 60000,
    "testMatch": [
      "**/tests/integration/**/*.test.js"
    ],
    "testEnvironmentOptions": {
      "MONGOMS_DOWNLOAD_DIR": "./.mongoms"
    }
  }
}
